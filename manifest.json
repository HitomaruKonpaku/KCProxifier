{
  "manifest_version": 2,
  "name": "KCProxifier",
  "version": "2.0",
  "icons": {
    "16": "/assets/icons/KCProxifier_blue_16.png",
    "32": "/assets/icons/KCProxifier_blue_32.png",
    "128": "/assets/icons/KCProxifier_blue_128.png"
  },
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "https://play.games.dmm.com/game/kancolle",
    "*://*.kancolle-server.com/*"
  ],
  "background": {
    "scripts": [
      "js/background.js"
    ]
  },
  "browser_action": {
    "default_icon": "/assets/icons/KCProxifier_blue_32.png",
    "default_popup": "popup.html",
    "default_title": "KCProxifier"
  }
}
